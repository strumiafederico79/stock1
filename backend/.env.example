# ======================
# App
# ======================
APP_NAME=Stock Control Pro
API_PREFIX=/api/v1
DEBUG=false

# ======================
# Database
# Local rápido:
# DATABASE_URL=sqlite:///./stock_control.db
# Producción con Postgres:
# DATABASE_URL=postgresql+psycopg2://stock_user:stock_pass@db:5432/stock_db
# ======================
DATABASE_URL=sqlite:///./stock_control.db

# ======================
# CORS
# ======================
CORS_ORIGINS_RAW=http://localhost:5173,http://localhost:4173,http://localhost,http://127.0.0.1:5173

# ======================
# Barcode / QR
# ======================
BARCODE_TYPE_DEFAULT=CODE128

# ======================
# Security
# IMPORTANTE: cambiar en producción
# ======================
JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ======================
# Seed admin inicial
# IMPORTANTE: cambiar en producción
# ======================
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin1234
DEFAULT_ADMIN_FULL_NAME=Administrador General
