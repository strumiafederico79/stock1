# ======================
# Docker Compose (root)
# Copiar a .env en la raíz del repo
# ======================

# --- DB ---
POSTGRES_DB=stock_db
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=stock_pass
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8080
APP_NAME=Stock Control Pro
DEBUG=false
DATABASE_URL=postgresql+psycopg2://stock_user:stock_pass@db:5432/stock_db
CORS_ORIGINS_RAW=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173,http://localhost:80
BARCODE_TYPE_DEFAULT=CODE128
JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin1234
DEFAULT_ADMIN_FULL_NAME=Administrador General

# --- Frontend ---
FRONTEND_PORT=80
VITE_API_URL=/api/v1
